{
  "$schema": "https://schema.tauri.app/config/2.0.0",
  "productName": "WellnessMate",
  "version": "0.1.0",
  "identifier": "com.example.wellnessmate",
  "build": {
    "frontendDist": "../web/build",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "WellnessMate",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "copyright": "",
    "category": "Utility",
    "shortDescription": "AI-powered health and posture companion",
    "longDescription": "WellnessMate is your personal AI health companion that helps monitor posture, provides health insights, and promotes wellness habits."
  }
}